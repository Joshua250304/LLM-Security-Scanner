# Copy this file to .env and fill in the credentials for whichever
# provider(s) you plan to scan. Never commit your real .env file.

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Custom / self-hosted endpoint ---
CUSTOM_LLM_ENDPOINT=
CUSTOM_LLM_API_KEY=

# --- Scanner behaviour (optional, sensible defaults provided) ---
SCANNER_TIMEOUT=30
SCANNER_MAX_RETRIES=2
SCANNER_RATE_LIMIT=20
SCANNER_REPORT_DIR=reports
